{
  "name": "agentforge",
  "version": "0.1.0",
  "description": "Multi-repo + git-worktree workspace bootstrapper for Claude Code, Cursor, and OpenAI Codex CLI",
  "keywords": [
    "claude-code",
    "claude",
    "cursor",
    "codex",
    "agent",
    "ai",
    "monorepo",
    "multi-repo",
    "worktree",
    "workspace",
    "cli",
    "skills"
  ],
  "license": "MIT",
  "author": "seunghwan-swing <seunghwan@theswing.co.kr>",
  "bin": {
    "agentforge": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
